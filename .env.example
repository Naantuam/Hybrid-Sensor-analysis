# ------------------------------------------------------------------------------
# Hybrid Sensor Framework - Environment Configurations
# ------------------------------------------------------------------------------

# Port for the local Edge Server (defaults to 4444)
PORT=4444

# Set to true if deploying to a cloud server environment (e.g. Railway, Render)
IS_CLOUD=false

# ------------------------------------------------------------------------------
# Database Configurations (PostgreSQL)
# ------------------------------------------------------------------------------
# Specify the connection string for your Railway Postgres database.
# Note: From your local machine, you MUST use the Public/External Connection String
# Example: postgresql://postgres:PASSWORD@junction.proxy.rlwy.net:PORT/railway
DATABASE_URL=

# ------------------------------------------------------------------------------
# Resilient Communication (Optional)
# ------------------------------------------------------------------------------
# Cloud WebSocket endpoint URL for local Kali machine sync forwarding
CLOUD_WS_URL=

# ------------------------------------------------------------------------------
# Agent Settings (Optional)
# ------------------------------------------------------------------------------
# Specify a fallback ADB device serial number if multiple devices are attached
ADB_SERIAL=
